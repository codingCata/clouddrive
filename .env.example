# CloudDrive Environment Configuration
# Copy this file to .env and fill in your values

# REQUIRED: Secret key for session encryption
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Database path (optional, defaults to clouddrive.db)
DB_PATH=

# Storage directory (optional, defaults to storage/)
STORAGE_DIR=

# Flask environment (set to 'production' for production deployments)
FLASK_ENV=development
